{
  "firestore": {
    "rules": "firebase/firestore.rules"
  },
  "storage": {
    "rules": "firebase/storage.rules"
  },
  "hosting": [
    {
      "target": "app",
      "public": "app/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "redirects": [
        { "source": "/", "destination": "https://mindcraft-marketing-site.web.app/", "type": 302 },
        { "source": "/landing.html", "destination": "https://mindcraft-marketing-site.web.app/", "type": 301 },
        { "source": "/blog.html", "destination": "https://mindcraft-marketing-site.web.app/blog.html", "type": 301 },
        { "source": "/article.html", "destination": "https://mindcraft-marketing-site.web.app/article.html", "type": 301 }
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "/index.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/login",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/dashboard",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/practice",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/knowledge-graph",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/assets/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ]
    },
    {
      "target": "world1",
      "public": "worlds/world2",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "/mc-diagnostic.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        },
        {
          "source": "/mc-diagnostic.css",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        },
        {
          "source": "/data/actDiagnostic.json",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        },
        {
          "source": "/assets/**",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        }
      ]
    },
    {
      "target": "marketing",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        ".git/**",
        ".github/**",
        ".firebase/**",
        ".claude/**",
        "**/node_modules/**",
        "app/**",
        "functions/**",
        "webhook/**",
        "ml/**",
        "homework/**",
        "worlds/**",
        "docs/**",
        "img/*.3mf",
        "img/*.tex",
        "img/*.pptx",
        "img/*.mp3",
        "img/*.py",
        "package*.json",
        "firestore*",
        "storage.rules",
        "serve-spa.mjs",
        "make_deck.py",
        "*.pdf",
        "*.xlsx",
        "*.md",
        "*.log",
        "Logo.png",
        "kite.jpg"
      ],
      "rewrites": []
    }
  ]
}
