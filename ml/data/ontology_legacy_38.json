        "geometry",
        "visual",
        "computation"
      ]
    },
    {
      "id": "circles_geometry",
      "name": "Geometry of Circles",
      "level": "core",
      "typical_order": 19,
      "description": "Analyzing chords, secants, tangents, and calculating arc lengths and sector areas.",
      "tags": [
        "geometry",
        "visual",
        "computation"
      ]
    },
    {
      "id": "area_volume",
      "name": "Area and Volume",
      "level": "core",
      "typical_order": 20,
      "description": "Calculating the two-dimensional area and three-dimensional volume of geometric figures.",
