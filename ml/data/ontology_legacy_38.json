        "geometry",
        "visual",
        "applied",
        "computation"
      ]
    },
    {
      "id": "geometric_transformations",
      "name": "Geometric Transformations",
      "level": "core",
      "typical_order": 21,
      "description": "Translating, rotating, reflecting, and dilating figures on a coordinate plane.",
