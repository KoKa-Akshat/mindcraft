# Copy this file to .env and fill in your values
# These are set as Vercel environment variables in production (not committed)

# Firebase Admin SDK service account
# Get from: Firebase Console → Project Settings → Service accounts → Generate new private key
# Paste the entire JSON as a single line (no newlines)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Anthropic API key for Claude (JARVIS + summary generation)
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Fireflies.ai API key for transcript fetching
# Get from: fireflies.ai → Settings → API → API Key
FIREFLIES_API_KEY=
