      "typical_order": 23,
      "description": "Understanding imaginary numbers and performing arithmetic operations on complex values.",
      "tags": [
        "algebra",
        "symbolic",
        "conceptual"
      ]
    },
    {
      "id": "exponential_functions",
      "name": "Exponential Functions",
      "level": "core",
