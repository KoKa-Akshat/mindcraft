rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /chat-files/{chatId}/{allPaths=**} {
      allow read, write: if request.auth != null && (
        chatId.split('_')[0] == request.auth.uid ||
        chatId.split('_')[1] == request.auth.uid
      );
    }
    match /sessions/{sessionId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /users/{uid}/stickers/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 300 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|svg\\+xml)');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
