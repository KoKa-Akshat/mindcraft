        "calculus",
        "symbolic",
        "continuous",
        "procedural"
      ]
    },
    {
      "id": "applications_of_integrals",
      "name": "Applications of Integrals",
      "level": "advanced",
      "typical_order": 37,
      "description": "Applying integration to find areas between curves, volumes of solids of revolution, and net change.",
      "tags": [
        "calculus",
        "applied",
        "continuous",
        "visual"
      ]
    },
    {
      "id": "inferential_statistics",
      "name": "Inferential Statistics",
      "level": "advanced",
