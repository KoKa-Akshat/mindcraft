# MindCraft environment variables
# Copy this file to .env and fill in your values.
# Never commit the actual .env file.

# ── Anthropic (required by all Claude calls) ──────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Firebase / Firestore ──────────────────────────────────────────────────────
# Path to a Firebase service account JSON (for Python services)
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ── Webhook (Vercel) ──────────────────────────────────────────────────────────
# Firebase Admin SDK credentials (set in Vercel env panel, not a file)
FIREBASE_PROJECT_ID=mindcraft-93858
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── ML server (Cloud Run) ─────────────────────────────────────────────────────
ML_URL=https://mindcraft-ml-630302850770.us-central1.run.app

# ── Homework service (Cloud Run) ──────────────────────────────────────────────
HOMEWORK_API_URL=http://localhost:8001

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_ML_API_URL=https://mindcraft-ml-630302850770.us-central1.run.app
VITE_HOMEWORK_API_URL=http://localhost:8001

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
