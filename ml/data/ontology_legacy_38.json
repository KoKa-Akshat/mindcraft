    {
      "id": "fractions_decimals",
      "name": "Fractions and Decimals",
      "level": "foundational",
      "typical_order": 1,
      "description": "Understanding, converting, and performing arithmetic operations on fractional and decimal values.",
      "tags": [
        "arithmetic",
        "computation",
        "procedural",
        "numeric"
      ]
    },
    {
      "id": "ratios_proportions",
      "name": "Ratios and Proportions",
      "level": "foundational",
      "typical_order": 2,
      "description": "Comparing quantities and solving for unknowns by setting equivalent ratios.",
      "tags": [
        "arithmetic",
        "applied",
        "procedural",
        "numeric"
      ]
    },
    {
      "id": "order_of_operations",
      "name": "Order of Operations",
      "level": "foundational",
      "typical_order": 3,
      "description": "Evaluating mathematical expressions systematically using standard priority rules.",
      "tags": [
        "arithmetic",
        "computation",
        "procedural",
        "symbolic"
      ]
    },
    {
      "id": "basic_equations",
      "name": "Basic One-Variable Equations",
      "level": "foundational",
      "typical_order": 4,
      "description": "Solving simple algebraic equations for a single unknown variable using inverse operations.",
      "tags": [
        "algebra",
        "symbolic",
        "procedural"
      ]
    },
    {
      "id": "linear_equations",
      "name": "Linear Equations",
      "level": "core",
      "typical_order": 5,
      "description": "Graphing and solving equations of the first degree, understanding slope and y-intercept.",
      "tags": [
        "algebra",
        "symbolic",
        "visual",
        "procedural"
      ]
    },
    {
      "id": "linear_inequalities",
      "name": "Linear Inequalities",
      "level": "core",
      "typical_order": 6,
      "description": "Solving and graphing inequalities to find ranges of valid solutions.",
      "tags": [
        "algebra",
        "symbolic",
        "visual",
        "procedural"
      ]
    },
    {
      "id": "systems_of_linear_equations",
      "name": "Systems of Linear Equations",
      "level": "core",
      "typical_order": 7,
      "description": "Finding the common solution to two or more linear equations simultaneously.",
      "tags": [
        "algebra",
        "procedural",
        "visual",
        "computation"
      ]
    },
    {
      "id": "functions_basics",
      "name": "Basics of Functions",
      "level": "core",
      "typical_order": 8,
      "description": "Understanding function notation, domain, range, and the concept of inputs mapping to unique outputs.",
      "tags": [
        "algebra",
        "conceptual",
        "symbolic"
      ]
    },
    {
      "id": "exponent_rules",
      "name": "Exponent Rules",
      "level": "core",
      "typical_order": 9,
      "description": "Simplifying expressions using the properties of integer and rational exponents.",
      "tags": [
        "algebra",
        "symbolic",
        "computation",
        "procedural"
      ]
    },
    {
      "id": "polynomials",
      "name": "Polynomial Operations",
      "level": "core",
      "typical_order": 10,
      "description": "Adding, subtracting, multiplying, and dividing algebraic expressions with multiple terms.",
      "tags": [
        "algebra",
        "symbolic",
        "procedural",
        "computation"
      ]
    },
    {
      "id": "radical_expressions",
      "name": "Radical Expressions",
      "level": "core",
      "typical_order": 11,
      "description": "Simplifying and operating on expressions containing square roots and higher-order roots.",
      "tags": [
        "algebra",
        "symbolic",
        "computation"
      ]
    },
    {
      "id": "factoring_polynomials",
      "name": "Factoring Polynomials",
      "level": "core",
      "typical_order": 12,
      "description": "Decomposing polynomials into products of simpler polynomials.",
      "tags": [
        "algebra",
        "symbolic",
        "procedural"
      ]
    },
    {
      "id": "quadratic_equations",
      "name": "Quadratic Equations",
      "level": "core",
      "typical_order": 13,
      "description": "Solving second-degree polynomial equations using factoring, the quadratic formula, and completing the square.",
      "tags": [
        "algebra",
        "symbolic",
        "visual",
        "procedural"
      ]
    },
    {
      "id": "descriptive_statistics",
      "name": "Descriptive Statistics",
      "level": "core",
      "typical_order": 14,
      "description": "Summarizing data using measures of center (mean, median, mode) and spread (variance, standard deviation).",
      "tags": [
        "statistics",
        "applied",
        "computation",
        "numeric"
      ]
    },
    {
      "id": "basic_probability",
      "name": "Basic Probability",
      "level": "core",
      "typical_order": 15,
      "description": "Calculating the likelihood of simple and compound events using combinatorial logic.",
      "tags": [
        "statistics",
        "discrete",
        "applied",
        "procedural"
      ]
    },
    {
      "id": "lines_angles",
      "name": "Lines and Angles",
      "level": "core",
      "typical_order": 16,
      "description": "Understanding geometric properties of intersecting lines, parallel lines, and angle relationships.",
      "tags": [
        "geometry",
        "visual",
        "conceptual"
      ]
    },
    {
      "id": "triangles_congruence",
      "name": "Triangles and Congruence",
      "level": "core",
      "typical_order": 17,
      "description": "Proving triangles congruent or similar and applying properties of interior and exterior angles.",
