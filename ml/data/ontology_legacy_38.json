        "geometry",
        "visual",
        "procedural"
      ]
    },
    {
      "id": "rational_expressions",
      "name": "Rational Expressions",
      "level": "core",
      "typical_order": 22,
      "description": "Simplifying, adding, and solving equations involving algebraic fractions.",
      "tags": [
        "algebra",
        "symbolic",
        "procedural"
      ]
    },
    {
      "id": "complex_numbers",
      "name": "Complex Numbers",
